DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=Hello@789
DB_NAME=bloodbank

SAMPLE_ADMIN_ENABLED=true
SAMPLE_ADMIN_NAME="System Administrator"
SAMPLE_ADMIN_USERNAME=admin
SAMPLE_ADMIN_PHONE=+923001234567
SAMPLE_ADMIN_PASSWORD=admin123
SAMPLE_ADMIN_PASSWORD_HASH='$2y$12$OVbuDK6i1p3jMJs6iDj3aemaGPAZ8KrRbwh8y67Xd.hSiYPg5I5Ay'

SESSION_NAME=bbms_session
SESSION_LIFETIME=3600
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

SMS_API_URL=https://api.yoursmsgateway.com/send
SMS_API_KEY=REPLACE_WITH_API_KEY
SMS_SENDER_ID=BBMS
ALERT_STAFF_NUMBERS=+11234567890

BACKUP_MYSQLDUMP_PATH=mysqldump
BACKUP_RETENTION_DAYS=3
BACKUP_DRIVE_ENABLED=false
BACKUP_DRIVE_FOLDER_ID=REPLACE_FOLDER_ID
BACKUP_SERVICE_ACCOUNT_JSON=backend/service-account.json

# Google Drive Integration for Report Export
# Enable reports to be uploaded to Google Drive instead of local downloads
# Get credentials from: https://console.cloud.google.com

# Path to Google Drive credentials JSON file
# Download from Cloud Console > Service Account Keys or OAuth 2.0 Credentials
# Keep this file OUTSIDE the web root and never commit to version control
# Recommended location: /var/secrets/google/credentials.json
# Set permissions: chmod 600 /var/secrets/google/credentials.json
GOOGLE_DRIVE_CREDENTIALS_PATH=/var/secrets/google/credentials.json

# Google Drive folder ID where report files will be saved
# Get the ID from Google Drive folder URL: https://drive.google.com/drive/folders/{FOLDER_ID}
# Must create folder and grant access to service account if using Service Account auth
GOOGLE_DRIVE_FOLDER_ID=REPLACE_WITH_FOLDER_ID
